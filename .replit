modules = ["nodejs-22", "python-3.11"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "API"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Web"

[[workflows.workflow]]
name = "API"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run dev --workspace=@feastpot/api"
waitForPort = 3001

[[workflows.workflow]]
name = "Web"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run dev --workspace=@feastpot/web"
waitForPort = 3000

[workflows.workflow.metadata]
outputType = "console"

[[ports]]
localPort = 3000
externalPort = 3000

[[ports]]
localPort = 3001
externalPort = 3001

[deployment]
deploymentTarget = "autoscale"
run = ["bash", "-c", "npm run db:deploy && npm run start:api"]
build = ["bash", "-c", "npm ci && npm run db:generate && npm run build:api"]
