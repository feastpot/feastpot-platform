{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "Feastpot NestJS",
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "Node",
    "target": "ES2022",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "sourceMap": true,
    "declaration": false,
    "declarationMap": false
  }
}
