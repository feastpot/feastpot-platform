{
  "name": "feastpot-platform",
  "private": true,
  "version": "0.1.0",
  "packageManager": "npm@10.8.2",
  "engines": {
    "node": ">=22.0.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "start": "turbo run start",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "test:e2e": "turbo run test:e2e",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "clean": "turbo run clean && rm -rf node_modules .turbo",
    "db:generate": "prisma generate --schema=prisma/schema.prisma",
    "db:migrate": "prisma migrate dev --schema=prisma/schema.prisma",
    "db:deploy": "bash scripts/db-deploy.sh",
    "db:seed": "ts-node prisma/seed.ts",
    "db:studio": "prisma studio --schema=prisma/schema.prisma",
    "db:validate": "prisma validate --schema=prisma/schema.prisma",
    "db:reset": "prisma migrate reset --schema=prisma/schema.prisma --force",
    "db:backfill-coords": "ts-node scripts/backfill-delivery-coords.ts",
    "verify:payouts": "ts-node scripts/verify-payout-reconciliation.ts",
    "ci": "turbo run lint typecheck test build",
    "build:api": "turbo run build --filter=@feastpot/api",
    "start:api": "node apps/api/dist/main.js",
    "smoke-test": "ts-node --project tsconfig.json scripts/smoke-test.ts"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts",
    "schema": "prisma/schema.prisma"
  },
  "devDependencies": {
    "@prisma/client": "^5.22.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.1",
    "eslint-config-next": "^15.0.3",
    "eslint-config-prettier": "^9.1.0",
    "eslint-import-resolver-typescript": "^3.6.3",
    "eslint-plugin-import": "^2.31.0",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "lint-staged": "^15.2.10",
    "prettier": "^3.3.3",
    "prisma": "^5.22.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "turbo": "latest",
    "typescript": "^5.6.3"
  },
  "overrides": {
    "lodash": "^4.18.0",
    "js-yaml": "^4.1.1",
    "postcss": "^8.5.10",
    "serialize-javascript": "^7.0.5"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  }
}
