// Feastpot Prisma schema
// UK diaspora bulk food marketplace

generator client {
  provider        = "prisma-client-js"
  previewFeatures = []
}

datasource db {
  provider  = "postgresql"
  url       = env("SUPABASE_DB_URL")
  directUrl = env("SUPABASE_DIRECT_URL")
}

// ============================================================
// ENUMS (24)
// ============================================================

enum UserRole {
  customer
  vendor
  admin
  support
  finance
  compliance
}

enum UserStatus {
  active
  suspended
  deleted
}

enum VendorStatus {
  pending
  approved
  live
  suspended
  probation
  removed
}

enum OrderType {
  standard
  event
  subscription
}

enum OrderStatus {
  pending
  accepted
  needs_clarification
  preparing
  ready
  dispatched
  delivered
  cancelled
  rejected
  refunded
}

enum ItemCategory {
  tray
  soup
  protein
  swallow
  snack
  frozen
  bundle
  event
}

enum DeliveryType {
  local
  collection
  nationwide
}

enum DocumentType {
  hygiene_cert
  insurance
  photo_id
  bank_details
  kitchen_reg
}

enum DocumentStatus {
  pending
  verified
  rejected
  expired
}

enum PaymentType {
  capture
  refund
  partial_refund
  credit
}

enum PaymentStatus {
  pending
  succeeded
  failed
  cancelled
}

enum PayoutStatus {
  draft
  held
  approved
  transferred
  failed
}

enum DisputeStatus {
  open
  vendor_contacted
  resolved
  escalated
  closed
}

enum IssueType {
  missing_items
  wrong_order
  quality
  not_delivered
  other
}

enum Severity {
  low
  medium
  high
}

enum ResolutionType {
  full_refund
  partial_refund
  credit
  rejected
  escalated
}

enum EnquiryStatus {
  open
  quoted
  confirmed
  completed
  cancelled
  // D16: distinguishes operational SLA failure (no quote within 48h)
  // from active cancellation. Drives "vendor unresponsive" analytics.
  expired
}

enum QuoteStatus {
  submitted
  accepted
  rejected
  expired
}

enum ModerationStatus {
  auto_approved
  held
  approved
  rejected
}

enum LoyaltyTxType {
  earned
  redeemed
  expired
  adjusted
}

enum ReferralStatus {
  pending
  completed
  rewarded
}

enum NotificationChannel {
  email
  whatsapp
  sms
  push
}

enum NotificationStatus {
  queued
  sent
  delivered
  failed
}

enum EvidenceType {
  photo
  document
  screenshot
}

enum DiscountType {
  flat
  percentage
}

// ============================================================
// MODELS (21)
// ============================================================

model User {
  id            String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email         String     @unique @db.VarChar(255)
  phone         String?    @unique @db.VarChar(32)
  passwordHash  String?    @map("password_hash") @db.VarChar(255)
  firstName     String?    @map("first_name") @db.VarChar(100)
  lastName      String?    @map("last_name") @db.VarChar(100)
  role          UserRole   @default(customer)
  status        UserStatus @default(active)
  emailVerified Boolean    @default(false) @map("email_verified")
  phoneVerified Boolean    @default(false) @map("phone_verified")
  avatarUrl     String?    @map("avatar_url") @db.VarChar(500)
  lastLoginAt   DateTime?  @map("last_login_at") @db.Timestamptz
  createdAt     DateTime   @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime   @updatedAt @map("updated_at") @db.Timestamptz

  sessions       Session[]
  addresses      Address[]
  notifications  Notification[]
  vendor         Vendor?
  orders         Order[]
  disputes       Dispute[]
  payments       Payment[]
  reviews        Review[]
  loyaltyPoints  LoyaltyPoint[]
  referralsMade  Referral[]      @relation("ReferralReferrer")
  referralsGot   Referral[]      @relation("ReferralReferee")
  auditLogs      AuditLog[]
  eventEnquiries EventEnquiry[]
  pushSubscriptions PushSubscription[]
  createdDiscountCodes DiscountCode[] @relation("CreatedDiscountCodes")
  reviewedVendorApplications VendorApplication[] @relation("VendorApplicationReviewer")

  @@index([role])
  @@index([status])
  @@index([createdAt])
  @@map("users")
}

model Session {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  refreshToken String   @unique @map("refresh_token") @db.VarChar(255)
  userAgent    String?  @map("user_agent") @db.VarChar(500)
  ipAddress    String?  @map("ip_address") @db.VarChar(64)
  expiresAt    DateTime @map("expires_at") @db.Timestamptz
  revokedAt    DateTime? @map("revoked_at") @db.Timestamptz
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

model Address {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  label      String?  @db.VarChar(100)
  line1      String   @db.VarChar(255)
  line2      String?  @db.VarChar(255)
  city       String   @db.VarChar(100)
  postcode   String   @db.VarChar(16)
  country    String   @default("GB") @db.VarChar(2)
  latitude   Float?
  longitude  Float?
  isDefault  Boolean  @default(false) @map("is_default")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamptz

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders Order[]

  @@index([userId])
  @@index([postcode])
  @@map("addresses")
}

model PushSubscription {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  endpoint  String   @unique @db.VarChar(500)
  p256dh    String   @db.VarChar(255)
  auth      String   @db.VarChar(255)
  userAgent String?  @map("user_agent") @db.VarChar(255)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("push_subscriptions")
}

model Notification {
  id        String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String              @map("user_id") @db.Uuid
  channel   NotificationChannel
  status    NotificationStatus  @default(queued)
  template  String              @db.VarChar(100)
  subject   String?             @db.VarChar(255)
  body      String
  metadata  Json?
  sentAt    DateTime?           @map("sent_at") @db.Timestamptz
  createdAt DateTime            @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([channel])
  @@index([createdAt])
  @@map("notifications")
}

/// Vendor registration leads captured from the public become-a-vendor form.
/// Distinct from `Vendor` (which requires an authenticated User) - applicants
/// don't have accounts yet. Admin review converts an approved application
/// into a full Vendor + User pair.
model VendorApplication {
  id               String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  fullName         String                  @map("full_name") @db.VarChar(255)
  kitchenName      String                  @map("kitchen_name") @db.VarChar(255)
  email            String                  @db.VarChar(255)
  phone            String                  @db.VarChar(40)
  postcode         String                  @db.VarChar(16)
  cuisineType      String                  @map("cuisine_type") @db.VarChar(64)
  kitchenType      String                  @map("kitchen_type") @db.VarChar(40)
  hasFsaRegistration Boolean               @map("has_fsa_registration")
  foodStory        String
  instagram        String?                 @db.VarChar(255)
  marketingConsent Boolean                 @default(true) @map("marketing_consent")
  status           VendorApplicationStatus @default(pending)
  reviewedAt       DateTime?               @map("reviewed_at") @db.Timestamptz
  reviewedById     String?                 @map("reviewed_by_id") @db.Uuid
  // adminNotes: free-form internal notes (visible to admins, never to the
  // applicant). Also doubles as the body of an "information_requested"
  // message - the email template surfaces it to the applicant verbatim.
  adminNotes       String?                 @map("admin_notes")
  // rejectionReason: surfaced to the applicant in the rejection email.
  // Separate from adminNotes so we never leak internal triage commentary.
  rejectionReason  String?                 @map("rejection_reason")
  // Populated by the approval flow when we provision the real Vendor row.
  // ON DELETE SET NULL so removing a vendor (rare, GDPR) doesn't erase the
  // permanent application record.
  vendorId         String?                 @unique @map("vendor_id") @db.Uuid
  // Vendor T&Cs acceptance audit. Nullable because pre-existing
  // applications were captured before the explicit-consent contract was
  // introduced; new submissions always populate both fields. Version is
  // a free-form tag (e.g. "2026-05") so legal can bump it without a
  // schema migration when terms change.
  acceptedTermsAt       DateTime? @map("accepted_terms_at") @db.Timestamptz
  acceptedTermsVersion  String?   @map("accepted_terms_version") @db.VarChar(32)
  createdAt        DateTime                @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime                @updatedAt @map("updated_at") @db.Timestamptz

  reviewedBy User?   @relation("VendorApplicationReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
  vendor     Vendor? @relation("VendorApplicationVendor", fields: [vendorId], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@index([email])
  @@map("vendor_applications")
}

enum VendorApplicationStatus {
  pending
  under_review
  information_requested
  approved
  rejected
}

/// Anonymous log of every public vendor search. Powers admin "search trends"
/// + vendor-recruitment ("we get N searches/week for X but have no vendors").
/// Intentionally has NO userId/IP so it stays out of GDPR DSAR scope.
model SearchLog {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  query        String   @db.VarChar(200)
  postcode     String?  @db.VarChar(10)
  resultsCount Int      @map("results_count")
  searchedAt   DateTime @default(now()) @map("searched_at") @db.Timestamptz

  @@index([query, searchedAt(sort: Desc)])
  @@index([searchedAt(sort: Desc)])
  @@map("search_logs")
}

model Vendor {
  id              String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId          String       @unique @map("user_id") @db.Uuid
  businessName    String       @map("business_name") @db.VarChar(255)
  slug            String       @unique @db.VarChar(255)
  description     String?
  cuisines        String[]     @db.VarChar(64)
  status          VendorStatus @default(pending)
  rating          Float        @default(0)
  ratingCount     Int          @default(0) @map("rating_count")
  reorderRatePct  Float        @default(0) @map("reorder_rate_pct")
  communityFavourite Boolean   @default(false) @map("community_favourite")
  commissionBps   Int          @default(1200) @map("commission_bps")
  stripeAccountId String?      @map("stripe_account_id") @db.VarChar(100)
  payoutsEnabled  Boolean      @default(false) @map("payouts_enabled")
  approvedAt      DateTime?    @map("approved_at") @db.Timestamptz
  suspendedAt     DateTime?    @map("suspended_at") @db.Timestamptz

  // Availability & scheduling (T002).
  // openingDays uses 0=Sun … 6=Sat to match JavaScript Date#getDay(),
  // which is what both the customer checkout SlotPicker and the order
  // intake validator already use. Defaults keep behaviour identical to
  // the pre-T002 hardcoded OrderSlotsService defaults so unmigrated
  // vendors continue to work.
  openingDays              Int[]   @default([0, 1, 2, 3, 4, 5, 6]) @map("opening_days")
  slotOpenHour             Int     @default(9)  @map("slot_open_hour")
  slotCloseHour            Int     @default(21) @map("slot_close_hour")
  prepLeadHours            Int     @default(24) @map("prep_lead_hours")
  maxOrdersPerDay          Int?    @map("max_orders_per_day")
  maxTraysPerDay           Int?    @map("max_trays_per_day")
  sameDayOrders            Boolean @default(false) @map("same_day_orders")
  largeOrderLeadHours      Int?    @map("large_order_lead_hours")
  largeOrderTrayThreshold  Int?    @map("large_order_tray_threshold")
  eventCateringManualQuote Boolean @default(false) @map("event_catering_manual_quote")

  // Business profile additions (T005). All optional/additive so existing
  // vendors keep working untouched.
  // - logoUrl / coverImageUrl: previously implicit; promoted to first-class
  //   columns so the profile editor can write to them via PATCH.
  // - specialities: short tags surfaced as pills on the customer page,
  //   distinct from cuisines (which are coarse categories).
  // - vendorStory: long-form bio rendered below the description.
  // - featuredDishes: free-text names highlighted at the top of the menu;
  //   not a foreign key to MenuItem so vendors can call out off-menu /
  //   seasonal favourites without a publishing round-trip.
  // - socialLinks: JSON blob keyed by network (instagram / tiktok / web /
  //   facebook / youtube). JSON keeps the schema flexible while the
  //   editor settles on which networks matter.
  logoUrl         String?  @map("logo_url")
  coverImageUrl   String?  @map("cover_image_url")
  specialities    String[] @default([]) @db.VarChar(64)
  vendorStory     String?  @map("vendor_story")
  featuredDishes  String[] @default([]) @map("featured_dishes") @db.VarChar(120)
  socialLinks     Json?    @map("social_links")

  createdAt       DateTime     @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime     @updatedAt @map("updated_at") @db.Timestamptz

  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  menus          Menu[]
  menuItems      MenuItem[]
  deliveryConfig DeliveryConfig?
  documents      VendorDocument[]
  blackoutDates  BlackoutDate[]
  orders         Order[]
  payouts        Payout[]
  reviews        Review[]
  eventQuotes    EventQuote[]
  selectedForEnquiries EventEnquiry[] @relation("EventEnquirySelectedVendor")
  discountCodes  DiscountCode[]
  amendments     OrderAmendment[]
  application    VendorApplication? @relation("VendorApplicationVendor")

  @@index([status])
  @@index([slug])
  @@index([rating])
  @@index([communityFavourite])
  @@map("vendors")
}

// Dates a vendor is closed: holidays, personal time, fully booked, etc.
// One row per (vendor, calendar date) - the unique index lets us upsert
// idempotently from the vendor UI and lets the order-slot validator do a
// fast lookup by (vendorId, date).
model BlackoutDate {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  vendorId  String   @map("vendor_id") @db.Uuid
  date      DateTime @db.Date
  reason    String?  @db.VarChar(255)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  vendor Vendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@unique([vendorId, date])
  @@index([vendorId, date])
  @@map("blackout_dates")
}

model Menu {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  vendorId  String   @map("vendor_id") @db.Uuid
  name      String   @db.VarChar(255)
  isActive  Boolean  @default(true) @map("is_active")
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  vendor Vendor     @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  items  MenuItem[]

  @@index([vendorId])
  @@index([isActive])
  @@map("menus")
}

model MenuItem {
  id               String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  vendorId         String           @map("vendor_id") @db.Uuid
  menuId           String           @map("menu_id") @db.Uuid
  name             String           @db.VarChar(255)
  description      String?
  category         ItemCategory
  pricePence       Int              @map("price_pence")
  servingsCount    Int?             @map("servings_count")
  preparationHours Int              @default(24) @map("preparation_hours")
  imageUrls        String[]         @map("image_urls") @db.VarChar(500)
  allergens        String[]         @db.VarChar(64)
  tags             String[]         @db.VarChar(64)
  isAvailable      Boolean          @default(false) @map("is_available")
  stockCount       Int?             @map("stock_count")
  moderationStatus ModerationStatus @default(auto_approved) @map("moderation_status")
  createdAt        DateTime         @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime         @updatedAt @map("updated_at") @db.Timestamptz

  vendor     Vendor      @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  menu       Menu        @relation(fields: [menuId], references: [id], onDelete: Cascade)
  orderItems OrderItem[]

  @@index([vendorId])
  @@index([menuId])
  @@index([category])
  @@index([isAvailable])
  @@index([moderationStatus])
  @@map("menu_items")
}

model DeliveryConfig {
  id                   String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  vendorId             String         @unique @map("vendor_id") @db.Uuid
  types                DeliveryType[]
  localRadiusMiles     Int            @default(5) @map("local_radius_miles")
  localFeePence        Int            @default(0) @map("local_fee_pence")
  collectionAddress    String?        @map("collection_address") @db.VarChar(500)
  nationwideEnabled    Boolean        @default(false) @map("nationwide_enabled")
  nationwideFeePence   Int            @default(0) @map("nationwide_fee_pence")
  minOrderPence        Int            @default(0) @map("min_order_pence")
  freeDeliveryOverPence Int?          @map("free_delivery_over_pence")
  postcodes            String[]       @db.VarChar(16)
  latitude             Float?
  longitude            Float?
  createdAt            DateTime       @default(now()) @map("created_at") @db.Timestamptz
  updatedAt            DateTime       @updatedAt @map("updated_at") @db.Timestamptz

  vendor Vendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@index([latitude, longitude])
  @@map("delivery_configs")
}

model VendorDocument {
  id          String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  vendorId    String         @map("vendor_id") @db.Uuid
  type        DocumentType
  status      DocumentStatus @default(pending)
  fileUrl     String         @map("file_url") @db.VarChar(500)
  fileName    String?        @map("file_name") @db.VarChar(255)
  expiresAt   DateTime?      @map("expires_at") @db.Timestamptz
  reviewedBy  String?        @map("reviewed_by") @db.Uuid
  reviewedAt  DateTime?      @map("reviewed_at") @db.Timestamptz
  rejectReason String?       @map("reject_reason")
  createdAt   DateTime       @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime       @updatedAt @map("updated_at") @db.Timestamptz

  vendor Vendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@index([vendorId])
  @@index([type])
  @@index([status])
  @@index([expiresAt])
  @@map("vendor_documents")
}

model AuditLog {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  actorId    String?  @map("actor_id") @db.Uuid
  action     String   @db.VarChar(100)
  entityType String   @map("entity_type") @db.VarChar(64)
  entityId   String?  @map("entity_id") @db.Uuid
  metadata   Json?
  ipAddress  String?  @map("ip_address") @db.VarChar(64)
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz

  actor User? @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([actorId])
  @@index([entityType, entityId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

model Order {
  id                String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderNumber       String      @unique @map("order_number") @db.VarChar(32)
  customerId        String      @map("customer_id") @db.Uuid
  vendorId          String      @map("vendor_id") @db.Uuid
  addressId         String?     @map("address_id") @db.Uuid
  type              OrderType   @default(standard)
  status            OrderStatus @default(pending)
  deliveryType      DeliveryType @map("delivery_type")
  subtotalPence     Int         @map("subtotal_pence")
  deliveryFeePence  Int         @default(0) @map("delivery_fee_pence")
  serviceFeePence   Int         @default(0) @map("service_fee_pence")
  discountPence     Int         @default(0) @map("discount_pence")
  totalPence        Int         @map("total_pence")
  commissionPence   Int         @default(0) @map("commission_pence")
  vendorPayoutPence Int         @default(0) @map("vendor_payout_pence")
  notes             String?
  scheduledFor      DateTime?   @map("scheduled_for") @db.Timestamptz
  acceptedAt        DateTime?   @map("accepted_at") @db.Timestamptz
  dispatchedAt      DateTime?   @map("dispatched_at") @db.Timestamptz
  deliveredAt       DateTime?   @map("delivered_at") @db.Timestamptz
  cancelledAt       DateTime?   @map("cancelled_at") @db.Timestamptz
  cancellationReason String?    @map("cancellation_reason")
  cancelledBy       String?     @map("cancelled_by") @db.VarChar(32)
  discountCodeId    String?     @map("discount_code_id") @db.Uuid
  discountAppliedAt DateTime?   @map("discount_applied_at") @db.Timestamptz(6)
  etaMinutes        Int?        @map("eta_minutes")
  etaAt             DateTime?   @map("eta_at") @db.Timestamptz
  createdAt         DateTime    @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime    @updatedAt @map("updated_at") @db.Timestamptz

  customer     User          @relation(fields: [customerId], references: [id])
  vendor       Vendor        @relation(fields: [vendorId], references: [id])
  address      Address?      @relation(fields: [addressId], references: [id])
  discountCode DiscountCode? @relation("DiscountCodeOrders", fields: [discountCodeId], references: [id])
  items      OrderItem[]
  payments   Payment[]
  payouts    Payout[]
  disputes   Dispute[]
  reviews    Review[]
  amendments OrderAmendment[]

  @@index([customerId])
  @@index([vendorId])
  @@index([status])
  @@index([type])
  @@index([createdAt])
  @@index([orderNumber])
  @@map("orders")
}

enum AmendmentStatus {
  pending
  accepted
  declined
  expired
}

model OrderAmendment {
  id              String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderId         String          @map("order_id") @db.Uuid
  vendorId        String          @map("vendor_id") @db.Uuid
  proposedChange  String          @map("proposed_change")
  priceDeltaPence Int             @default(0) @map("price_delta_pence")
  status          AmendmentStatus @default(pending)
  expiresAt       DateTime        @map("expires_at") @db.Timestamptz
  respondedAt     DateTime?       @map("responded_at") @db.Timestamptz
  createdAt       DateTime        @default(now()) @map("created_at") @db.Timestamptz

  order  Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  vendor Vendor @relation(fields: [vendorId], references: [id])

  @@index([orderId, status])
  @@map("order_amendments")
}

model OrderItem {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderId      String   @map("order_id") @db.Uuid
  menuItemId   String   @map("menu_item_id") @db.Uuid
  nameSnapshot String   @map("name_snapshot") @db.VarChar(255)
  quantity     Int
  unitPence    Int      @map("unit_pence")
  totalPence   Int      @map("total_pence")
  notes        String?
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz

  order    Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItem MenuItem @relation(fields: [menuItemId], references: [id])

  @@index([orderId])
  @@index([menuItemId])
  @@map("order_items")
}

model EventEnquiry {
  id                String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  customerId        String        @map("customer_id") @db.Uuid
  eventType         String        @map("event_type") @db.VarChar(100)
  guestCount        Int           @map("guest_count")
  finalGuestCount   Int?          @map("final_guest_count")
  eventDate         DateTime      @map("event_date") @db.Timestamptz
  postcode          String        @db.VarChar(16)
  budgetPence       Int?          @map("budget_pence")
  cuisines          String[]      @db.VarChar(64)
  dietary           String[]      @db.VarChar(32)
  notes             String?
  menuAdjustments   String?       @map("menu_adjustments")
  status            EnquiryStatus @default(open)
  vendorId          String?       @map("vendor_id") @db.Uuid
  matchedVendorIds  String[]      @map("matched_vendor_ids") @db.Uuid
  quoteDeadline     DateTime?     @map("quote_deadline") @db.Timestamptz
  depositPiId       String?       @map("deposit_pi_id") @db.VarChar(100)
  balancePiId       String?       @map("balance_pi_id") @db.VarChar(100)
  confirmedAt       DateTime?     @map("confirmed_at") @db.Timestamptz
  createdAt         DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime      @updatedAt @map("updated_at") @db.Timestamptz

  customer       User         @relation(fields: [customerId], references: [id], onDelete: Cascade)
  selectedVendor Vendor?      @relation("EventEnquirySelectedVendor", fields: [vendorId], references: [id], onDelete: SetNull)
  quotes         EventQuote[]

  @@index([customerId])
  @@index([status])
  @@index([eventDate])
  @@index([postcode])
  @@index([vendorId])
  @@map("event_enquiries")
}

model EventQuote {
  id               String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  enquiryId        String      @map("enquiry_id") @db.Uuid
  vendorId         String      @map("vendor_id") @db.Uuid
  pricePence       Int         @map("price_pence")
  perHeadPence     Int         @default(0) @map("per_head_pence")
  deliveryFeePence Int         @default(0) @map("delivery_fee_pence")
  minDepositPct    Int         @default(30) @map("min_deposit_pct")
  proposedMenu     String?     @map("proposed_menu")
  terms            String?
  message          String?
  menuOutline      Json?       @map("menu_outline")
  status           QuoteStatus @default(submitted)
  expiresAt        DateTime?   @map("expires_at") @db.Timestamptz
  acceptedAt       DateTime?   @map("accepted_at") @db.Timestamptz
  createdAt        DateTime    @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime    @updatedAt @map("updated_at") @db.Timestamptz

  enquiry EventEnquiry @relation(fields: [enquiryId], references: [id], onDelete: Cascade)
  vendor  Vendor       @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@unique([enquiryId, vendorId])
  @@index([enquiryId])
  @@index([vendorId])
  @@index([status])
  @@map("event_quotes")
}

model Dispute {
  id             String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderId        String          @map("order_id") @db.Uuid
  raisedById     String          @map("raised_by_id") @db.Uuid
  issueType      IssueType       @map("issue_type")
  severity       Severity        @default(low)
  description    String
  status         DisputeStatus   @default(open)
  assignedToId   String?         @map("assigned_to_id") @db.Uuid
  vendorResponse String?         @map("vendor_response")
  vendorRespondedAt DateTime?    @map("vendor_responded_at") @db.Timestamptz
  resolution     ResolutionType?
  resolutionNote String?         @map("resolution_note")
  resolvedById   String?         @map("resolved_by_id") @db.Uuid
  resolvedAt     DateTime?       @map("resolved_at") @db.Timestamptz
  createdAt      DateTime        @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime        @updatedAt @map("updated_at") @db.Timestamptz

  order    Order              @relation(fields: [orderId], references: [id], onDelete: Cascade)
  raisedBy User               @relation(fields: [raisedById], references: [id])
  evidence DisputeEvidence[]

  @@unique([orderId])
  @@index([orderId])
  @@index([raisedById])
  @@index([assignedToId])
  @@index([status])
  @@index([severity])
  @@index([createdAt])
  @@map("disputes")
}

model DisputeEvidence {
  id         String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  disputeId  String       @map("dispute_id") @db.Uuid
  type       EvidenceType
  fileUrl    String       @map("file_url") @db.VarChar(500)
  caption    String?      @db.VarChar(500)
  uploadedBy String       @map("uploaded_by") @db.Uuid
  createdAt  DateTime     @default(now()) @map("created_at") @db.Timestamptz

  dispute Dispute @relation(fields: [disputeId], references: [id], onDelete: Cascade)

  @@index([disputeId])
  @@index([type])
  @@map("dispute_evidence")
}

model Payment {
  id                    String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderId               String        @map("order_id") @db.Uuid
  userId                String        @map("user_id") @db.Uuid
  type                  PaymentType   @default(capture)
  status                PaymentStatus @default(pending)
  amountPence           Int           @map("amount_pence")
  currency              String        @default("GBP") @db.VarChar(3)
  stripePaymentIntentId String?       @map("stripe_payment_intent_id") @db.VarChar(100)
  stripeChargeId        String?       @map("stripe_charge_id") @db.VarChar(100)
  stripeRefundId        String?       @unique @map("stripe_refund_id") @db.VarChar(100)
  failureReason         String?       @map("failure_reason")
  processedAt           DateTime?     @map("processed_at") @db.Timestamptz
  createdAt             DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt             DateTime      @updatedAt @map("updated_at") @db.Timestamptz

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id])

  @@index([orderId])
  @@index([userId])
  @@index([status])
  @@index([type])
  @@index([createdAt])
  @@index([stripePaymentIntentId])
  @@map("payments")
}

model Payout {
  id                String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  vendorId          String       @map("vendor_id") @db.Uuid
  orderId           String?      @map("order_id") @db.Uuid
  status            PayoutStatus @default(draft)
  amountPence       Int          @map("amount_pence")
  grossPence        Int          @default(0) @map("gross_pence")
  commissionPence   Int          @default(0) @map("commission_pence")
  refundsPence      Int          @default(0) @map("refunds_pence")
  periodStart       DateTime?    @map("period_start") @db.Timestamptz
  periodEnd         DateTime?    @map("period_end") @db.Timestamptz
  orderCount        Int          @default(0) @map("order_count")
  holdReason        String?      @map("hold_reason")
  currency          String       @default("GBP") @db.VarChar(3)
  stripeTransferId  String?      @map("stripe_transfer_id") @db.VarChar(100)
  approvedById      String?      @map("approved_by_id") @db.Uuid
  approvedAt        DateTime?    @map("approved_at") @db.Timestamptz
  transferredAt     DateTime?    @map("transferred_at") @db.Timestamptz
  failureReason     String?      @map("failure_reason")
  createdAt         DateTime     @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime     @updatedAt @map("updated_at") @db.Timestamptz

  vendor Vendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  order  Order? @relation(fields: [orderId], references: [id])

  @@index([vendorId])
  @@index([orderId])
  @@index([status])
  @@index([createdAt])
  @@index([vendorId, periodEnd])
  @@unique([vendorId, periodEnd], name: "payouts_vendor_period_unique")
  @@map("payouts")
}

model ProcessedWebhookEvent {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  stripeEventId   String   @unique @map("stripe_event_id") @db.VarChar(100)
  eventType       String   @map("event_type") @db.VarChar(100)
  processedAt     DateTime @default(now()) @map("processed_at") @db.Timestamptz

  @@index([eventType])
  @@map("processed_webhook_events")
}

model Review {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderId    String   @map("order_id") @db.Uuid
  vendorId   String   @map("vendor_id") @db.Uuid
  customerId String   @map("customer_id") @db.Uuid
  rating           Int
  title            String?          @db.VarChar(255)
  body             String?
  isVerified       Boolean          @default(true) @map("is_verified")
  isHidden         Boolean          @default(false) @map("is_hidden")
  moderationStatus ModerationStatus @default(auto_approved) @map("moderation_status")
  moderatedById    String?          @map("moderated_by_id") @db.Uuid
  moderatedAt      DateTime?        @map("moderated_at") @db.Timestamptz
  createdAt        DateTime         @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime         @updatedAt @map("updated_at") @db.Timestamptz

  order    Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  vendor   Vendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  customer User   @relation(fields: [customerId], references: [id])

  @@unique([orderId])
  @@unique([orderId, customerId])
  @@index([vendorId])
  @@index([customerId])
  @@index([rating])
  @@index([createdAt])
  @@index([moderationStatus])
  @@map("reviews")
}

model LoyaltyPoint {
