  orderId     String?       @map("order_id") @db.Uuid
  expiresAt   DateTime?     @map("expires_at") @db.Timestamptz
  createdAt   DateTime      @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([type])
  @@index([expiresAt])
  @@index([createdAt])
  @@map("loyalty_points")
}

model Referral {
  id           String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  referrerId   String         @map("referrer_id") @db.Uuid
  refereeId    String?        @map("referee_id") @db.Uuid
  code         String         @unique @db.VarChar(32)
  status       ReferralStatus @default(pending)
  rewardPence  Int            @default(0) @map("reward_pence")
  completedAt  DateTime?      @map("completed_at") @db.Timestamptz
  rewardedAt   DateTime?      @map("rewarded_at") @db.Timestamptz
  createdAt    DateTime       @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime       @updatedAt @map("updated_at") @db.Timestamptz

  referrer User  @relation("ReferralReferrer", fields: [referrerId], references: [id], onDelete: Cascade)
  referee  User? @relation("ReferralReferee", fields: [refereeId], references: [id])

  @@index([referrerId])
  @@index([refereeId])
  @@index([status])
  @@index([code])
  @@map("referrals")
}

model DiscountCode {
  id              String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code            String       @unique @db.VarChar(30)
  type            DiscountType
  value           Int
  minOrderPence   Int          @default(0) @map("min_order_pence")
  maxUses         Int?         @map("max_uses")
  usedCount       Int          @default(0) @map("used_count")
  expiresAt       DateTime?    @map("expires_at") @db.Timestamptz
  vendorId        String?      @map("vendor_id") @db.Uuid
  isActive        Boolean      @default(true) @map("is_active")
  createdByUserId String       @map("created_by_user_id") @db.Uuid
  createdAt       DateTime     @default(now()) @map("created_at") @db.Timestamptz

  vendor    Vendor? @relation(fields: [vendorId], references: [id])
  createdBy User    @relation("CreatedDiscountCodes", fields: [createdByUserId], references: [id])
  orders    Order[] @relation("DiscountCodeOrders")

  @@index([code])
  @@index([isActive, expiresAt])
  @@map("discount_codes")
}
