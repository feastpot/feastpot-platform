# Public Supabase config — safe to expose, inlined into the client bundle.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Public Stripe key — used by @stripe/stripe-js in the browser.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Server-only Stripe secret — never expose to the client.
STRIPE_SECRET_KEY=
