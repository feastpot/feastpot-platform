# --------------------------------------------------------------------
# Customer PWA (apps/web)
# Copy to .env.local for dev. In Vercel, set the same keys per project.
# Anything NEXT_PUBLIC_* is inlined into the client bundle.
# --------------------------------------------------------------------

# Supabase (Settings → API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Backend API. Dev fallback in src/lib/env.ts is http://localhost:3001.
# Prod: https://api.feastpot.co.uk (or https://feastpot-platform.replit.app
# until the api.feastpot.co.uk DNS is wired).
NEXT_PUBLIC_API_URL=

# Public Stripe key — used by @stripe/stripe-js in the browser.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Server-only Stripe secret — never expose to the client.
STRIPE_SECRET_KEY=

# Used by metadataBase, sitemap, OG canonical URLs.
# Dev: http://localhost:3000   Prod: https://feastpot.co.uk
NEXT_PUBLIC_SITE_URL=

# Web Push (VAPID). Same key value as on the API.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# Customer-facing support contacts (rendered on /help and footer).
NEXT_PUBLIC_SUPPORT_EMAIL=support@feastpot.co.uk
NEXT_PUBLIC_SUPPORT_WHATSAPP=

# Rendered on /legal/privacy. Replace before launch.
NEXT_PUBLIC_ICO_NUMBER=
