# --------------------------------------------------------------------
# Vendor portal (apps/vendor)
# --------------------------------------------------------------------

# Supabase (Settings → API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Backend API. Dev fallback in src/lib/env.ts is http://localhost:3001.
# Prod: https://api.feastpot.co.uk
NEXT_PUBLIC_API_URL=

# Public Stripe key (Connect onboarding redirect lands back here).
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Web Push (VAPID). Same key value as on the API.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# Customer PWA URL - used for "view storefront" links back to the public site.
NEXT_PUBLIC_WEB_URL=
