# ═══════════════════════════════════════════════════════
# FEASTPOT — Environment Variables Reference (apps/api + Prisma + scripts)
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
#
# This template lists only variables actually read by the server
# (process.env / ConfigService.get / Prisma env()). Frontend
# NEXT_PUBLIC_* vars live in apps/{web,vendor,admin}/.env.example.
# ═══════════════════════════════════════════════════════

# ── Supabase ────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJh...
SUPABASE_SERVICE_ROLE_KEY=eyJh...
# Pooled connection used by the app at runtime (Prisma datasource url).
SUPABASE_DB_URL=postgresql://postgres:password@db.your-project.supabase.co:6543/postgres?pgbouncer=true
# Direct (non-pooled) connection used for migrations (Prisma directUrl).
SUPABASE_DIRECT_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# ── Stripe ──────────────────────────────────────────────
# Use sk_test_ for development, sk_live_ for production.
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Redis (Upstash / BullMQ) ────────────────────────────
REDIS_URL=rediss://default:password@your-host.upstash.io:6380

# ── Email (Resend) ──────────────────────────────────────
RESEND_API_KEY=re_test_...
EMAIL_FROM=hello@feastpot.co.uk
EMAIL_LOGO_URL=https://feastpot.co.uk/images/feastpot-logo.png

# ── SMS / WhatsApp (Twilio) ─────────────────────────────
TWILIO_ACCOUNT_SID=ACxx...
TWILIO_AUTH_TOKEN=...
TWILIO_FROM_NUMBER=+447700000000
TWILIO_WHATSAPP_FROM=whatsapp:+447700000000

# ── WhatsApp (Meta Cloud API) ───────────────────────────
WHATSAPP_ACCESS_TOKEN=EAAxx...
WHATSAPP_PHONE_NUMBER_ID=1234567890

# ── Push Notifications (Web Push / VAPID) ───────────────
VAPID_PUBLIC_KEY=BPxx...
VAPID_PRIVATE_KEY=...
VAPID_SUBJECT=mailto:push@feastpot.co.uk

# ── Platform config ─────────────────────────────────────
# Service fee in basis points (500 = 5%).
SERVICE_FEE_BPS=500
# Menu auto-approve: "true" for trusted cohort, "false" for self-serve review.
MENU_AUTO_APPROVE=true
# MFA recovery code pepper (generate with: openssl rand -hex 32).
MFA_RECOVERY_PEPPER=...

# ── URLs ────────────────────────────────────────────────
API_URL=http://localhost:3001
API_PUBLIC_URL=https://api.feastpot.co.uk
VENDOR_PORTAL_URL=https://vendor.feastpot.co.uk
ADMIN_URL=https://admin.feastpot.co.uk

# ── Bull Board (queue monitor) ──────────────────────────
BULL_BOARD_USERNAME=admin
BULL_BOARD_PASSWORD=change-me-in-production

# ── Ops / Alerts ────────────────────────────────────────
DLQ_ALERT_EMAIL=ops@feastpot.co.uk
VENDOR_APPLICATIONS_ADMIN_EMAIL=vendors@feastpot.co.uk
SENTRY_DSN=https://xxx@sentry.io/yyy

# ── Runtime ─────────────────────────────────────────────
NODE_ENV=development
PORT=3001

# ── Seed / Test credentials (CI / local seeding only) ───
# Guard that must be "true" to allow `db:seed` against a prod NODE_ENV.
ALLOW_SEED_IN_PROD=false
TEST_ADMIN_EMAIL=soul@feastpot.co.uk
TEST_ADMIN_PASSWORD=...
CUSTOMER_EMAIL=customer@feastpot.co.uk
CUSTOMER_PASSWORD=...
VENDOR_EMAIL=vendor@feastpot.co.uk
VENDOR_PASSWORD=...
